# Скопируйте в frontend/.env.
# VAPID public key фронтенд не хранит — получает его в рантайме через
# GET /api/v1/push/vapid-public-key (публичный эндпоинт, см. docs/03-SETUP-DEPLOY.md §3.5),
# чтобы не дублировать значение между Vercel и Render/бэкендом.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
