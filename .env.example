# ============================================================
# SPI Messenger — шаблон переменных окружения.
# Скопируйте в .env и заполните. Файл .env в .gitignore.
# Один .env обслуживает и docker compose (прод-стек), и локальный backend.
# Подробности по каждому блоку — docs/03-SETUP-DEPLOY.md.
# ============================================================

# --- Развёртывание: домен и HTTPS (docker compose + Caddy, ADR-023) ---
# DOMAIN — на нём Caddy автоматически выпустит HTTPS-сертификат (Let's Encrypt).
#   демо/прод:  DOMAIN=demo.spi-2015.ru
#   локально по http без сертификата:  DOMAIN=:80
DOMAIN=
ACME_EMAIL=                        # e-mail для уведомлений Let's Encrypt (необязательно)

# --- База данных (PostgreSQL 16) ---
# Прод-стек (docker compose): ОСТАВЬТЕ ПУСТЫМ — api подключится к сервису postgres
#   из compose по паролю POSTGRES_PASSWORD (см. ниже).
# Локальная разработка на хосте (docker-compose.dev.yml поднимает только БД):
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spi_messenger
# Внешняя managed-БД (опционально): postgresql+asyncpg://user:PASSWORD@host:5432/dbname
DATABASE_URL=

# --- Безопасность ---
JWT_SECRET=                        # openssl rand -hex 32  (в prod обязателен)
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Режим ---
APP_ENV=dev                        # dev | prod (dev: коды входа пишутся в лог, письма не шлются)

# --- Файловое хранилище ---
# local — файлы на постоянном томе uploads (в compose переживают рестарт/редеплой).
STORAGE_BACKEND=local              # local | s3 (supabase — заглушка, не реализован)
STORAGE_LOCAL_PATH=/data/uploads   # том uploads в контейнере api (для STORAGE_BACKEND=local)
S3_ENDPOINT=                       # для s3/minio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=spi-media

# --- Почта (коды входа; пусто = код печатается в лог, письма не уходят) ---
# Провайдер — smtp.bz, отправитель — домен spi-2015.ru (см. docs/03-SETUP-DEPLOY.md §1):
# хост/порт/логин/пароль — из личного кабинета smtp.bz (Настройки → SMTP), не отсюда.
SMTP_HOST=smtp.bz
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@spi-2015.ru

# --- Web Push ---
VAPID_PUBLIC_KEY=                  # npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@spi-2015.ru

# --- Поиск GIF (Tenor) — необязательно, пусто = вкладка GIF скрыта на фронте ---
TENOR_API_KEY=

# --- Прочее ---
# При same-origin деплое (Caddy отдаёт и фронт, и API) CORS фактически не задействуется;
# укажите свой домен для подстраховки. Локально — адрес vite-сервера.
CORS_ORIGINS=https://demo.spi-2015.ru
FRONTEND_URL=https://demo.spi-2015.ru
REDIS_URL=                         # пусто = in-process события/планировщик (1 инстанс, ADR-023)

# --- docker compose (прод-стек) ---
POSTGRES_PASSWORD=                 # пароль postgres в контейнере (используется и в DATABASE_URL по умолчанию)
