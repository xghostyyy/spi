# ============================================================
# SPI Messenger — шаблон переменных окружения (backend)
# Скопируйте в .env и заполните. Файл .env в .gitignore.
# Все значения-секреты генерируются локально, в репозиторий не попадают.
# ============================================================

# --- База данных (PostgreSQL 16 везде) ---
# Демо (Supabase):   postgresql+asyncpg://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
# Прод (VPS):        postgresql+asyncpg://spi_app:PASSWORD@postgres:5432/spi_messenger
# Локально (docker-compose.dev.yml): postgresql+asyncpg://postgres:postgres@localhost:5432/spi_messenger
DATABASE_URL=

# --- Безопасность ---
JWT_SECRET=                        # openssl rand -hex 32
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Режим ---
APP_ENV=dev                        # dev | prod (dev: коды входа пишутся в лог, письма не шлются)

# --- Файловое хранилище ---
STORAGE_BACKEND=local              # supabase | local | s3
SUPABASE_URL=
SUPABASE_SERVICE_KEY=              # только на сервере, никогда во фронт!
STORAGE_LOCAL_PATH=./data/uploads  # для STORAGE_BACKEND=local
S3_ENDPOINT=                       # для s3/minio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=spi-media

# --- Почта (коды входа; пусто в dev = код в лог) ---
# Провайдер — smtp.bz, отправитель — домен spi-2015.ru (см. docs/03-SETUP-DEPLOY.md §1.1):
# хост/порт/логин/пароль — из личного кабинета smtp.bz (Настройки → SMTP), не отсюда.
SMTP_HOST=smtp.bz
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@spi-2015.ru

# --- Web Push ---
VAPID_PUBLIC_KEY=                  # npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@spi-messenger.ru

# --- Прочее ---
CORS_ORIGINS=http://localhost:5173
REDIS_URL=                         # пусто = in-process events (1 инстанс)
FRONTEND_URL=http://localhost:5173

# --- docker-compose (prod VPS) ---
POSTGRES_PASSWORD=                 # пароль суперпользователя postgres в контейнере
DOMAIN=                            # домен для nginx/certbot
